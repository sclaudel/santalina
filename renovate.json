{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],

  "timezone": "Europe/Paris",

  "schedule": ["before 10am on monday"],

  "enabledManagers": ["gradle", "gradle-wrapper", "npm"],

  "prConcurrentLimit": 5,

  "prCreation": "not-pending",

  "minimumReleaseAge": "3 days",

  "osvVulnerabilityAlerts": true,

  "vulnerabilityAlerts": {
    "labels": ["security", "vulnerability"],
    "automerge": false
  },

  "reviewers": ["sclaudel"],

  "labels": ["dependencies"],

  "packageRules": [

    {
      "description": "Grouper toutes les dépendances Quarkus (BOM + extensions)",
      "matchPackageNames": ["io.quarkus**"],
      "groupName": "Quarkus",
      "addLabels": ["quarkus"],
      "automerge": false
    },

    {
      "description": "Mises à jour majeures : ne jamais auto-merger, tag explicite",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["breaking-change"],
      "prPriority": -1
    },

    {
      "description": "Mises à jour mineures",
      "matchUpdateTypes": ["minor"],
      "automerge": false,
      "addLabels": ["minor"]
    },

    {
      "description": "Mises à jour de patch",
      "matchUpdateTypes": ["patch"],
      "automerge": false,
      "addLabels": ["patch"]
    },

    {
      "description": "devDependencies npm groupées pour réduire le bruit",
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "groupName": "npm devDependencies",
      "addLabels": ["dev-dependencies"]
    },

    {
      "description": "Gradle Wrapper : mise à jour groupée",
      "matchManagers": ["gradle-wrapper"],
      "groupName": "Gradle Wrapper",
      "addLabels": ["gradle"]
    },

    {
      "description": "Alertes de vulnérabilité : priorité haute",
      "matchCategories": ["security"],
      "prPriority": 10
    }

  ]
}
