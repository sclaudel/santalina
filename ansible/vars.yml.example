# ── Variables Ansible — exemple ───────────────────────────────────────────────
# Copiez ce fichier en `vars.yml`, remplissez toutes les valeurs,
# puis NE LE COMMITEZ PAS (il contient des secrets).
# ─────────────────────────────────────────────────────────────────────────────

# Domaine public de l'application (doit pointer vers votre VPS)
app_domain: santalina.example.com

# Email pour les notifications Let's Encrypt (expiration, etc.)
letsencrypt_email: admin@example.com

# Répertoire de déploiement sur le VPS
app_dir: /opt/santalina

# Nom d'utilisateur DockerHub (identique au secret GitHub DOCKERHUB_USERNAME)
dockerhub_username: votre_username_dockerhub

# Tag de l'image à déployer ('latest' ou un numéro de version ex: '1.2.0')
app_image_tag: latest

# Obtenir automatiquement le certificat SSL Let's Encrypt lors du déploiement
# Mettre à false si le domaine ne pointe pas encore vers le VPS
obtain_ssl: true

# Générer un certificat auto-signé si Let's Encrypt n'est pas disponible
# Utile pour tester localement ou quand le domaine ne pointe pas encore vers le VPS
# Automatiquement ignoré si un certificat Let's Encrypt est déjà présent
self_signed_ssl: false

# ── Secrets applicatifs ────────────────────────────────────────────────────
app_db_password: "ChangeMeDbPassword123!"

app_admin_email: admin@santalina.com
app_admin_password: "ChangeMeAdminPassword!"

# ── Configuration SMTP ────────────────────────────────────────────────────
# Adresse d'expédition (doit correspondre au domaine déclaré dans app_domain ou son parent)
app_mailer_from: noreply@santalina.com

# Relay SMTP externe optionnel (laisser commenté pour envoi direct depuis le serveur)
# Si renseigné, le conteneur Postfix local relaie vers ce serveur au lieu d'envoyer directement.
# Exemple : app_smtp_relayhost: "[smtp.sendgrid.net]:587"
# app_smtp_relayhost: ""

# Désactiver l'envoi de mails (mode mock)
# Mettre à true tant que le domaine/SPF/DKIM ne sont pas configurés.
# Les emails seront logués dans l'application sans être envoyés.
# Remettre à false (ou supprimer) une fois l'authentification email en place.
# Voir : ansible/docs/smtp-authentication.md
mail_disabled: false

# ── Niveaux de log applicatifs ────────────────────────────────────────────
# Valeurs valides : TRACE, DEBUG, INFO, WARN, ERROR
# app_log_level      : niveau racine (laisser INFO en prod, DEBUG pour investiguer)
# app_app_log_level  : code org.santalina uniquement (surcharge app_log_level)
# app_mailer_log_level : couches SMTP — passer à DEBUG pour diagnostiquer l'envoi de mail
# app_log_level: INFO
# app_app_log_level: INFO
# app_mailer_log_level: INFO

# ── Configuration fail2ban ─────────────────────────────────────────────────
# Port SSH exposé sur le serveur (changer si SSH n'est pas sur le port par défaut)
# fail2ban_ssh_port: ssh

# Durée globale du bannissement (ex : 10m, 1h, 1d)
# fail2ban_bantime: "1h"

# Fenêtre de détection des tentatives
# fail2ban_findtime: "10m"

# Nombre de tentatives avant bannissement (global)
# fail2ban_maxretry: 5

# Paramètres spécifiques SSH (par défaut plus restrictifs)
# fail2ban_ssh_maxretry: 3
# fail2ban_ssh_bantime: "1h"

# Paramètres spécifiques brute-force endpoint /api/auth/login
# fail2ban_auth_maxretry: 5
# fail2ban_auth_bantime: "1h"
# fail2ban_auth_findtime: "10m"

# Durée de bannissement pour les bots/scans détectés
# fail2ban_botsearch_bantime: "24h"

# ── Import de données existantes (optionnel) ───────────────────────────────
# Chemin local (sur votre machine) vers un dump SQL à injecter au premier déploiement.
# Laisser commenté ou vide pour démarrer avec une base vierge.
# Peut aussi être passé en ligne de commande : -e "db_seed_file=/chemin/vers/dump.sql"
# db_seed_file: "/chemin/local/vers/dump.sql"
