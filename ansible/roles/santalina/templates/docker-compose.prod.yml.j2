services:

  # ── Base de données PostgreSQL (accès interne uniquement) ─────────────────
  db:
    image: postgres:16-alpine
    container_name: santalina-db
    restart: unless-stopped
    logging: &default-logging
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"
    environment:
      POSTGRES_DB: santalina
      POSTGRES_USER: santalina
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U santalina"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - internal

  # ── Application Quarkus (accès interne uniquement) ────────────────────────
  app:
    image: {{ dockerhub_username }}/santalina:{{ app_image_tag | default('latest') }}
    container_name: santalina-app
    restart: unless-stopped
    logging: *default-logging
    environment:
      QUARKUS_PROFILE: prod
      JDBC_URL: jdbc:postgresql://db:5432/santalina
      DB_USER: santalina
      DB_PASSWORD: ${DB_PASSWORD}
      ADMIN_EMAIL: ${ADMIN_EMAIL}
      ADMIN_PASSWORD: ${ADMIN_PASSWORD}
      MAILER_FROM: ${MAILER_FROM}
      APP_BASE_URL: "https://{{ app_domain }}"
      MAILER_HOST: smtp
      MAILER_PORT: "25"
      MAILER_START_TLS: DISABLED
      MAILER_SSL: "false"
      MAILER_TRUST_ALL: "false"
{% if mail_disabled | default(false) %}
      QUARKUS_MAILER_MOCK: "true"
{% endif %}
      LOG_LEVEL: "{{ app_log_level | default('INFO') }}"
      APP_LOG_LEVEL: "{{ app_app_log_level | default('INFO') }}"
      MAILER_LOG_LEVEL: "{{ app_mailer_log_level | default('INFO') }}"
      JWT_PRIVATE_KEY_PATH: /run/secrets/jwt_private_key
      JWT_PUBLIC_KEY_PATH: /run/secrets/jwt_public_key
      # Chemin du log SMTP monté en lecture seule depuis le conteneur smtp
      APP_LOGS_SMTP_PATH: /deployments/data/logs/smtp/mail.log
    secrets:
      - jwt_private_key
      - jwt_public_key
    depends_on:
      db:
        condition: service_healthy
      smtp:
        condition: service_healthy
    volumes:
      - app_data:/deployments/data
      # Logs applicatifs Quarkus — bind mount sur l'hôte pour logrotate / consultation
      - ./logs/app:/deployments/data/logs
      # Logs nginx — montés en lecture seule pour l'UI admin
      - ./logs/nginx:/deployments/data/logs/nginx:ro
      # Logs SMTP — montés en lecture seule pour l'UI admin
      - ./logs/smtp:/deployments/data/logs/smtp:ro
    networks:
      - internal

  # ── SMTP local — relay sortant uniquement (inaccessible depuis Internet) ───
  smtp:
    image: boky/postfix
    container_name: santalina-smtp
    restart: unless-stopped
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "15"
    environment:
      HOSTNAME: {{ app_domain }}
      ALLOWED_SENDER_DOMAINS: "{{ app_mailer_from | regex_replace('^.*@(.*)$', '\\1') }}"
      DKIM_AUTOGENERATE: "true"
{% if app_smtp_relayhost is defined and app_smtp_relayhost %}
      RELAYHOST: "{{ app_smtp_relayhost }}"
{% endif %}
    healthcheck:
      test: ["CMD-SHELL", "ss -tlnp | grep -q ':25' || exit 1"]
      interval: 15s
      timeout: 10s
      retries: 15
      start_period: 60s
    volumes:
      - ./dkim_keys:/etc/opendkim/keys
      # Expose /var/log/mail.log (rsyslog Debian) sur l'hôte pour l'UI admin
      - ./logs/smtp/mail.log:/var/log/mail.log
      # Surcharge rsyslog.conf : désactive imklog (interdit en conteneur non-privilégié)
      # et garantit l'écriture des logs mail dans le fichier bind-monté ci-dessus.
      - ./rsyslog-postfix.conf:/etc/rsyslog.conf:ro
    networks:
      - internal

  # ── Nginx — reverse proxy (seul service exposé sur Internet) ─────────────
  nginx:
    image: nginx:1.25-alpine
    container_name: santalina-nginx
    restart: unless-stopped
    logging: *default-logging
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - ./letsencrypt:/etc/letsencrypt:ro
      - ./certbot-www:/var/www/certbot:ro
      # Logs nginx accessibles depuis l'hôte pour fail2ban + logrotate
      - ./logs/nginx:/var/log/nginx
{% if self_signed_ssl | default(false) %}
      - ./certs:/etc/certs:ro
{% endif %}
    depends_on:
      - app
    networks:
      - internal

  # ── Certbot — renouvellement automatique des certificats SSL ─────────────
  certbot:
    image: certbot/certbot
    container_name: santalina-certbot
    restart: unless-stopped
    logging: *default-logging
    volumes:
      - ./letsencrypt:/etc/letsencrypt
      - ./certbot-www:/var/www/certbot
    entrypoint: >
      /bin/sh -c 'trap exit TERM;
      while :; do
        certbot renew --quiet --webroot -w /var/www/certbot;
        sleep 12h & wait $${!};
      done;'

# ── Réseau interne (app/db non accessibles depuis Internet) ──────────────────
networks:
  internal:
    driver: bridge

secrets:
  jwt_private_key:
    file: ./keys/privateKey.pem
  jwt_public_key:
    file: ./keys/publicKey.pem

volumes:
  postgres_data:
  app_data:
