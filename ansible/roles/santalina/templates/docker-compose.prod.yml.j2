services:

  # ── Base de données PostgreSQL (accès interne uniquement) ─────────────────
  db:
    image: postgres:16-alpine
    container_name: santalina-db
    restart: unless-stopped
    environment:
      POSTGRES_DB: santalina
      POSTGRES_USER: santalina
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U santalina"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - internal

  # ── Application Quarkus (accès interne uniquement) ────────────────────────
  app:
    image: {{ dockerhub_username }}/santalina:{{ app_image_tag | default('latest') }}
    container_name: santalina-app
    restart: unless-stopped
    environment:
      QUARKUS_PROFILE: prod
      JDBC_URL: jdbc:postgresql://db:5432/santalina
      DB_USER: santalina
      DB_PASSWORD: ${DB_PASSWORD}
      ADMIN_EMAIL: ${ADMIN_EMAIL}
      ADMIN_PASSWORD: ${ADMIN_PASSWORD}
      MAILER_FROM: ${MAILER_FROM}
      # Pointe vers le conteneur SMTP local sur le réseau interne
      MAILER_HOST: smtp
      MAILER_PORT: "25"
      # STARTTLS désactivé : connexion interne Docker, pas de TLS nécessaire
      MAILER_START_TLS: DISABLED
      MAILER_SSL: "false"
      MAILER_TRUST_ALL: "false"
{% if mail_disabled | default(false) %}
      # Mode mail désactivé : les emails sont logués sans être envoyés (DNS/SMTP non prêts)
      QUARKUS_MAILER_MOCK: "true"
{% endif %}
      # Niveaux de log (TRACE|DEBUG|INFO|WARN|ERROR)
      LOG_LEVEL: "{{ app_log_level | default('INFO') }}"
      APP_LOG_LEVEL: "{{ app_app_log_level | default('INFO') }}"
      MAILER_LOG_LEVEL: "{{ app_mailer_log_level | default('INFO') }}"
      JWT_PRIVATE_KEY_PATH: /run/secrets/jwt_private_key
      JWT_PUBLIC_KEY_PATH: /run/secrets/jwt_public_key
    secrets:
      - jwt_private_key
      - jwt_public_key
    depends_on:
      db:
        condition: service_healthy
      smtp:
        condition: service_healthy
    volumes:
      - app_data:/deployments/data
    networks:
      - internal

  # ── SMTP local — relay sortant uniquement (inaccessible depuis Internet) ───
  smtp:
    image: boky/postfix
    container_name: santalina-smtp
    restart: unless-stopped
    environment:
      HOSTNAME: {{ app_domain }}
      # Domaine autorisé à envoyer des mails (extrait de l'adresse expéditeur)
      ALLOWED_SENDER_DOMAINS: "{{ app_mailer_from | regex_replace('^.*@(.*)$', '\\1') }}"
      # Gènère automatiquement une paire de clés DKIM au démarrage si absente
      DKIM_AUTOGENERATE: "true"
{% if app_smtp_relayhost is defined and app_smtp_relayhost %}
      # Relay SMTP externe optionnel
      RELAYHOST: "{{ app_smtp_relayhost }}"
{% endif %}
    healthcheck:
      test: ["CMD-SHELL", "postfix status 2>/dev/null | grep -q 'postfix/postfix-script: the Postfix mail system is running'"]
      interval: 10s
      timeout: 5s
      retries: 12
      start_period: 30s
    volumes:
      # Persistance des clés DKIM — NE PAS supprimer ce volume !
      - dkim_keys:/etc/opendkim/domainkeys
    networks:
      - internal

  # ── Nginx — reverse proxy (seul service exposé sur Internet) ─────────────
  nginx:
    image: nginx:1.25-alpine
    container_name: santalina-nginx
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/conf.d/default.conf:ro
      # Bind mounts : les certificats restent sur le VPS même après docker compose down -v
      - ./letsencrypt:/etc/letsencrypt:ro
      - ./certbot-www:/var/www/certbot:ro
      # Logs nginx accessibles depuis l'hôte pour fail2ban
      - ./logs/nginx:/var/log/nginx
{% if self_signed_ssl | default(false) %}
      # Certificat auto-signé (ignoré si Let's Encrypt est utilisé)
      - ./certs:/etc/certs:ro
{% endif %}
    depends_on:
      - app
    networks:
      - internal

  # ── Certbot — renouvellement automatique des certificats SSL ─────────────
  certbot:
    image: certbot/certbot
    container_name: santalina-certbot
    restart: unless-stopped
    volumes:
      # Bind mounts : persistance garantie même après docker compose down -v
      - ./letsencrypt:/etc/letsencrypt
      - ./certbot-www:/var/www/certbot
    # Vérifie le renouvellement toutes les 12 heures
    entrypoint: >
      /bin/sh -c 'trap exit TERM;
      while :; do
        certbot renew --quiet --webroot -w /var/www/certbot;
        sleep 12h & wait $${!};
      done;'

# ── Réseau interne (app/db non accessibles depuis Internet) ──────────────────
networks:
  internal:
    driver: bridge
    
secrets:
  jwt_private_key:
    file: ./keys/privateKey.pem
  jwt_public_key:
    file: ./keys/publicKey.pem

volumes:
  postgres_data:
  app_data:
  # Clés DKIM — volume nommé pour éviter toute suppression accidentelle
  # Voir ansible/docs/smtp-authentication.md
  dkim_keys:
