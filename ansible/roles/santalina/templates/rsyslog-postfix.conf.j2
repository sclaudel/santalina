# ── rsyslog.conf — conteneur Postfix (boky/postfix) ──────────────────────────
# Déployé par Ansible — ne pas modifier manuellement.
#
# imklog est DÉSACTIVÉ : /proc/kmsg n'est pas accessible dans un conteneur
# non-privilégié et provoque des erreurs au démarrage ainsi que l'arrêt du
# traitement des logs.
#
# /var/spool/rsyslog n'existe pas dans l'image Alpine — on utilise /tmp.
# /dev/stdout n'est pas fiable dans rsyslog under Docker ; on pointe vers
# /proc/1/fd/1 (stdout du PID 1 du conteneur) ou on supprime cet output.
# ─────────────────────────────────────────────────────────────────────────────

# Socket Unix système (/dev/log) — source des messages Postfix/OpenDKIM
module(load="imuxsock")

$ActionFileDefaultTemplate RSYSLOG_TraditionalFileFormat
$FileCreateMode 0644
$DirCreateMode 0755
$Umask 0022
# Répertoire de travail rsyslog — /tmp disponible dans tous les conteneurs Alpine
$WorkDirectory /tmp/rsyslog

# ── Logs mail → fichier bind-monté sur l'hôte (logrotate + UI admin) ─────────
mail.*    /var/log/mail.log

# ── Tous les messages → stdout du conteneur (visible via docker compose logs) ─
*.*       /proc/1/fd/1
