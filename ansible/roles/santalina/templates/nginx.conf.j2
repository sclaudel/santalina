{% if ssl_mode | default('none') in ['letsencrypt', 'selfsigned'] %}
# ── Redirection HTTP → HTTPS ──────────────────────────────────────────────────
server {
    listen 80;
    server_name {{ app_domain }} www.{{ app_domain }};

    # Validation du certificat Let's Encrypt
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ── Redirection www → apex ───────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    server_name www.{{ app_domain }};

{% if ssl_mode | default('none') == 'selfsigned' %}
    ssl_certificate     /etc/certs/selfsigned.crt;
    ssl_certificate_key /etc/certs/selfsigned.key;
{% else %}
    ssl_certificate     /etc/letsencrypt/live/{{ app_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ app_domain }}/privkey.pem;
{% endif %}

    ssl_protocols             TLSv1.2 TLSv1.3;
    ssl_ciphers               ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache         shared:SSL:10m;
    ssl_session_timeout       1d;
    ssl_session_tickets       off;

    return 301 https://{{ app_domain }}$request_uri;
}

# ── Reverse proxy HTTPS ───────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    server_name {{ app_domain }};

{% if ssl_mode | default('none') == 'selfsigned' %}
    # Certificat auto-signé (développement — remplacé automatiquement par Let's Encrypt si disponible)
    ssl_certificate     /etc/certs/selfsigned.crt;
    ssl_certificate_key /etc/certs/selfsigned.key;
{% else %}
    # Certificats Let's Encrypt
    ssl_certificate     /etc/letsencrypt/live/{{ app_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ app_domain }}/privkey.pem;

    # HSTS (6 mois) — uniquement avec un certificat valide
    add_header Strict-Transport-Security "max-age=15768000" always;
{% endif %}

    # Protocoles et chiffrements recommandés (Mozilla Intermediate)
    ssl_protocols             TLSv1.2 TLSv1.3;
    ssl_ciphers               ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache         shared:SSL:10m;
    ssl_session_timeout       1d;
    ssl_session_tickets       off;

    add_header X-Content-Type-Options    nosniff;
    add_header X-Frame-Options           SAMEORIGIN;
    add_header X-XSS-Protection          "1; mode=block";

    # Taille maximale des uploads (PDF, exports…)
    client_max_body_size 25M;

    # Renouvellement Let's Encrypt
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Proxy vers l'application Quarkus
    location / {
        proxy_pass         http://app:8085;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_buffering    off;
    }
}
{% else %}
# ── HTTP uniquement (phase initiale avant obtention du certificat SSL) ─────────
server {
    listen 80;
    server_name {{ app_domain }} www.{{ app_domain }};

    # Validation Let's Encrypt
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Proxy HTTP direct (temporaire)
    location / {
        proxy_pass         http://app:8085;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }
}
{% endif %}
