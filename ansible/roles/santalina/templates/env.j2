# Variables d'environnement de production — générées par Ansible
DB_PASSWORD={{ app_db_password }}
ADMIN_EMAIL={{ app_admin_email }}
ADMIN_PASSWORD={{ app_admin_password }}
MAILER_FROM={{ app_mailer_from }}
MAILER_HOST={{ app_mailer_host }}
MAILER_PORT={{ app_mailer_port }}
# Clés JWT RSA (contenu PEM inline — évite tout problème de chemin/protocole)
MP_JWT_VERIFY_PUBLICKEY={{ lookup('file', app_dir + '/keys/publicKey.pem') | b64encode }}
SMALLRYE_JWT_SIGN_KEY={{ lookup('file', app_dir + '/keys/privateKey.pem') | b64encode }}
